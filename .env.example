# Supabase — transaction pooler (runtime, PgBouncer). Used by DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?schema=public&pgbouncer=true&connection_limit=10"

# Supabase — session pooler / direct connection (Prisma migrations & introspection).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
